VARIABLES

$var1 = get-random -minimum 25 -maximum 50 ##Create a variable called "var1" that holds a random number between 25-50##
$var2 = get-random -minimum 1 -maximum 10 ##Create a variable called "var2" that holds a random number between 1-10.##
$sum = ($var1 + $var2) ##Create a variable called "sum" that holds the sum of var1 and var2##
$sub = ($var1 - $var2) ##Create a variable called "sub" that holds the difference of var1 and var2##
$prod = ($var1 * $var2) ##Create a variable called "prod" that holds the product of var1 and var2##
$quo = ($var1 / $var2) ##Create a variable called "quo" that holds the quotient of var1 and var2##

write-host "`n$var1 + $var2 = $sum`n$var1 - $var2 = $sub`n$var1 * $var2 = $prod`n$var1 / $var2 = $quo" ##Replace the variables in text with their values##
