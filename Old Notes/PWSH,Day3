function pythag {
    $a = Read-Host -Prompt "Enter the length of a"
    $b =  Read-Host -Prompt "Enter the length of b"
    $asqr = [int]$a * [int]$a
    $bsqr = [int]$b * [int]$b
    $csqr = $asqr + $bsqr
    $c = [Math]::Sqrt([int]$csqr)
    echo "The hypotenuse is $c"
}

pythag

function deg {
    $a = Read-Host -Prompt "Enter the degrees of angle a on the triangle"
    $b =  Read-Host -Prompt "Enter the degrees of angle b on the triangle"
    $c = 180 - ([int]$a + [int]$b)
    if ( [int]$a + [int]$b + [int]$c -gt 180) {
        echo "Not a valid triangle"
    } elseif ([int]$a + [int]$b + [int]$c -lt 1) {
        echo "Not a valid triangle"
    } else {
        echo "The degree of angle C is $c"
    }
}

deg

